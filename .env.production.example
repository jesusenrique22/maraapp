# Copia a .env.production y completa los valores:
# cp .env.production.example .env.production

# URL pública donde verán la app (sin barra final)
PUBLIC_URL=https://tu-dominio.com

# Puerto local del contenedor web (80 en servidor, 8080 en pruebas locales)
WEB_PORT=80

# Copia a .env.production y completa los valores:
# cp .env.production.example .env.production

# URL pública donde verán la app (sin barra final)
PUBLIC_URL=https://tu-dominio.com

# Puerto local del contenedor web (80 en servidor, 8080 en pruebas locales)
WEB_PORT=80

# ─── Neon PostgreSQL (recomendado en producción) ───
# En neon.tech → Project → Connection details:
#   DATABASE_URL = "Pooled connection" (para la app)
#   DIRECT_URL   = "Direct connection"  (para migraciones / seed)
DATABASE_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Solo si usas docker-compose local con Postgres (no Neon):
POSTGRES_USER=maraplus
POSTGRES_PASSWORD=cambia-esta-clave-segura
POSTGRES_DB=maraplus

# Auth
JWT_SECRET=genera-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# Admin inicial (seed)
ADMIN_EMAIL=admin@maraplus.com
ADMIN_PASSWORD=CambiaEstaClave123!

# IA Maraia + escáner de recetas
GEMINI_API_KEY=

# Opcional
RAPIDAPI_KEY=
