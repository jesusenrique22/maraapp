# Copia a .env.neon y pega las URLs de Neon → smart-medic → Connect
# cp .env.neon.example .env.neon

# Pooled connection (para la app en Render)
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection (para migraciones y seed)
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Opcional: mismas credenciales admin que usarás en producción
ADMIN_EMAIL="admin@maraplus.com"
ADMIN_PASSWORD="Admin123!"
