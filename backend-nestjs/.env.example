# Copia este archivo a .env antes de levantar el backend:
# cp .env.example .env

DATABASE_URL="postgresql://maraplus:maraplus_dev@localhost:5433/maraplus?schema=public"
# En local puede ser igual que DATABASE_URL. En Neon usa la URL "direct" (sin pooler).
DIRECT_URL="postgresql://maraplus:maraplus_dev@localhost:5433/maraplus?schema=public"
PORT=3000

# URL pública del API (producción). Ej: https://maraplus.com
PUBLIC_API_URL="http://127.0.0.1:3000"

JWT_SECRET="maraplus-dev-secret-cambiar-en-produccion"
JWT_EXPIRES_IN="7d"

ADMIN_EMAIL="admin@maraplus.com"
ADMIN_PASSWORD="Admin123!"

# Maraia + escáner de recetas (Gemini)
GEMINI_API_KEY=""

# Opcional: clave de RapidAPI para precios reales de Walmart en búsqueda de bebidas.
RAPIDAPI_KEY=""
